# ============================================================================
# ToonFactory environment configuration
# Copy to .env and fill in. Everything except DATABASE_URL is optional in
# MOCK mode — providers fall back to deterministic mock implementations so the
# whole pipeline runs end-to-end with zero external API keys.
# ============================================================================

# ---- Core ----
NODE_ENV=development
DATABASE_URL="postgresql://toon:toon@localhost:5432/toonfactory?schema=public"
APP_BASE_URL=http://localhost:3000

# Set to "mock" to run the full pipeline with deterministic stubs (no API calls,
# no cost). Set to "live" to call the real providers configured below.
PIPELINE_MODE=mock

# Secret required by the cron + internal job endpoints (x-cron-secret header).
CRON_SECRET=change-me-to-a-long-random-string

# ---- Provider selection (swap providers without touching code) ----
LLM_PROVIDER=anthropic          # anthropic | openai | gemini | mock
IMAGE_PROVIDER=openai           # openai | gemini | stable-diffusion | flux | mock
VOICE_PROVIDER=elevenlabs       # elevenlabs | openai | google | mock
MUSIC_PROVIDER=mock             # suno | mock
ANIMATION_PROVIDER=mock         # runway | kling | mock
VIDEO_PROVIDER=ffmpeg           # ffmpeg | shotstack | mock

# ---- LLM keys ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ---- Image keys ----
# OPENAI_API_KEY reused for images (gpt-image-1)
STABILITY_API_KEY=
FLUX_API_KEY=

# ---- Voice keys ----
ELEVENLABS_API_KEY=
# Default ElevenLabs voice for the narrator + any unmapped character.
# Defaults to the public "Rachel" voice; override per-character in the DB.
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
GOOGLE_TTS_API_KEY=

# ---- Music / Animation keys ----
SUNO_API_KEY=
RUNWAY_API_KEY=
KLING_API_KEY=
SHOTSTACK_API_KEY=

# ---- Storage (S3-compatible: AWS S3, Cloudflare R2, Supabase, MinIO) ----
STORAGE_DRIVER=local            # local | s3
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=toonfactory
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ---- YouTube Data API v3 (OAuth2) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# ---- Production schedule ----
EPISODES_PER_DAY=2
SERIES_TITLE="The Adventures of Pip & Bramble"
TARGET_EPISODE_SECONDS=900

# The worker auto-produces the daily quota on its own (no external cron needed).
# Set to false to drive production only via /api/cron/produce (serverless hosts).
WORKER_AUTOPRODUCE=true
WORKER_AUTOPRODUCE_INTERVAL_MS=3600000
